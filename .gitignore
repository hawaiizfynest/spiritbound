*.md
!README.md

# Claude Code local settings
.claude/

# Virtual environments
.venv/
venv/
env/

# Test / tooling caches
.pytest_cache/
.mypy_cache/

# OS / editor cruft
.DS_Store
Thumbs.db
*.swp
.idea/
.vscode/
